#!/bin/sh

if [ "$#" -ne 1 ]; then
    echo "usage: mvx-agent-status <running|waiting|done|error>" >&2
    exit 64
fi

case "$1" in
    running|waiting|done|error)
        ;;
    *)
        echo "invalid state: $1" >&2
        exit 64
        ;;
esac

# OSC 9 - intercepted by Ghostty action callback
printf '\033]9;mvx-agent-status:%s\007' "$1"
# OSC 7777 - parsed by PtyBridge for fallback backend
printf '\033]7777;state=%s\007' "$1"
