#!/usr/bin/env bash
set -euo pipefail

# release-build — build mvx for release, stamp version, produce tarball + latest.json
#
# Required environment:
#   MVX_RELEASE_VERSION  — e.g. 0.1.5
#   MVX_BUILD_NUMBER     — e.g. 5
#
# Optional:
#   MVX_BUILD_DMG        — set to 0 to skip DMG creation (useful for CI)
#   MVX_ARCHIVE_DESTINATION — xcodebuild export destination specifier
#   MVX_ARCHIVE_ARCHS    — architectures to include in the archive

VERSION="${MVX_RELEASE_VERSION:?MVX_RELEASE_VERSION is required}"
BUILD="${MVX_BUILD_NUMBER:?MVX_BUILD_NUMBER is required}"
BUILD_DMG="${MVX_BUILD_DMG:-1}"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PROJECT_FILE="$PROJECT_ROOT/mvx.xcodeproj"
ARCHIVE_DEST="$PROJECT_ROOT/.build/release/mvx.xcarchive"
EXPORT_DEST="$PROJECT_ROOT/.build/release/export"
STAGING_DIR="$PROJECT_ROOT/.build/release/staging"

echo "==> Building mvx $VERSION ($BUILD)"

# Ensure xcodegen has run so the project file is current.
if command -v xcodegen &>/dev/null; then
    echo "==> Regenerating Xcode project from project.yml"
    xcodegen generate --project "$PROJECT_ROOT"
fi

# Clean previous build artifacts.
rm -rf "$ARCHIVE_DEST" "$EXPORT_DEST" "$STAGING_DIR"
mkdir -p "$EXPORT_DEST" "$STAGING_DIR"

# Build archive with version overrides.
ARCHIVE_LOG="$PROJECT_ROOT/.build/release/xcodebuild-archive.log"
xcodebuild archive \
    -project "$PROJECT_FILE" \
    -scheme Mvx \
    -configuration Release \
    -archivePath "$ARCHIVE_DEST" \
    -destination "${MVX_ARCHIVE_DESTINATION:-generic/platform=macOS}" \
    MARKETING_VERSION="$VERSION" \
    CURRENT_PROJECT_VERSION="$BUILD" \
    ARCHS="${MVX_ARCHIVE_ARCHS:-arm64}" \
    CODE_SIGN_IDENTITY="-" \
    CODE_SIGNING_REQUIRED=YES \
    DEVELOPMENT_TEAM="" \
    SKIP_INSTALL=NO \
    | tee "$ARCHIVE_LOG"

# Copy the archived app bundle into the export directory. This avoids
# `xcodebuild -exportArchive` distribution-method churn for direct-distribution
# macOS apps while still giving us a concrete app bundle to sign and package.
ARCHIVED_APP="$ARCHIVE_DEST/Products/Applications/mvx.app"
APP_BUNDLE="$EXPORT_DEST/mvx.app"

if [ ! -d "$ARCHIVED_APP" ]; then
    echo "ERROR: Archived app bundle not found at $ARCHIVED_APP" >&2
    exit 1
fi

echo "==> Copying archived app bundle"
cp -R "$ARCHIVED_APP" "$APP_BUNDLE"

# Verify the exported app bundle exists.
if [ ! -d "$APP_BUNDLE" ]; then
    echo "ERROR: mvx.app not found at $APP_BUNDLE" >&2
    exit 1
fi

# Verify Info.plist version/build match the expected values.
PLIST_VERSION=$(/usr/libexec/PlistBuddy -c "Print :CFBundleShortVersionString" "$APP_BUNDLE/Contents/Info.plist")
PLIST_BUILD=$(/usr/libexec/PlistBuddy -c "Print :CFBundleVersion" "$APP_BUNDLE/Contents/Info.plist")

if [ "$PLIST_VERSION" != "$VERSION" ]; then
    echo "ERROR: Info.plist CFBundleShortVersionString ($PLIST_VERSION) != MVX_RELEASE_VERSION ($VERSION)" >&2
    exit 1
fi

if [ "$PLIST_BUILD" != "$BUILD" ]; then
    echo "ERROR: Info.plist CFBundleVersion ($PLIST_BUILD) != MVX_BUILD_NUMBER ($BUILD)" >&2
    exit 1
fi

echo "==> Info.plist verified: $VERSION ($BUILD)"

# Re-apply ad-hoc signing and verify.
echo "==> Signing and verifying bundle"
codesign --sign - --force --deep --strict "$APP_BUNDLE"
codesign --verify --deep --strict "$APP_BUNDLE"
echo "==> Bundle signature verified"

# Create the tarball.
TARBALL_NAME="mvx-${VERSION}-${BUILD}-darwin-aarch64.app.tar.gz"
TARBALL_PATH="$STAGING_DIR/$TARBALL_NAME"

echo "==> Creating tarball: $TARBALL_NAME"
tar -czf "$TARBALL_PATH" -C "$EXPORT_DEST" mvx.app

# Compute SHA256.
SHA256=$(shasum -a 256 "$TARBALL_PATH" | awk '{print $1}')

echo "==> SHA256: $SHA256"

# Generate latest.json.
DOWNLOAD_URL="https://github.com/Saewt/mvx/releases/latest/download/$TARBALL_NAME"
cat > "$STAGING_DIR/latest.json" <<LATEST
{
  "version": "$VERSION",
  "build": "$BUILD",
  "minimum_macos": "13.0",
  "platforms": {
    "darwin-aarch64": {
      "url": "$DOWNLOAD_URL",
      "sha256": "$SHA256"
    }
  }
}
LATEST

echo "==> Generated latest.json"

# Generate release-publication.json (metadata for the release).
cat > "$STAGING_DIR/release-publication.json" <<PUB
{
  "version": "$VERSION",
  "build": "$BUILD",
  "tarball": "$TARBALL_NAME",
  "sha256": "$SHA256",
  "download_url": "$DOWNLOAD_URL"
}
PUB

echo "==> Generated release-publication.json"

# Optionally build a DMG for local distribution.
if [ "$BUILD_DMG" != "0" ]; then
    DMG_NAME="mvx-${VERSION}-${BUILD}.dmg"
    DMG_PATH="$STAGING_DIR/$DMG_NAME"

    echo "==> Creating DMG: $DMG_NAME"
    hdiutil create -volname "mvx" \
        -srcfolder "$EXPORT_DEST" \
        -ov -format UDZO \
        "$DMG_PATH"

    echo "==> DMG created at $DMG_PATH"
else
    echo "==> Skipping DMG creation (MVX_BUILD_DMG=0)"
fi

echo ""
echo "==> Release artifacts in $STAGING_DIR:"
ls -lh "$STAGING_DIR"
echo ""
echo "==> Done. Run release-publish to upload to GitHub."
