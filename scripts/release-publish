#!/usr/bin/env bash
set -euo pipefail

# release-publish — upload release artifacts to a GitHub Release
#
# Required environment:
#   MVX_RELEASE_VERSION  — e.g. 0.1.5
#   MVX_BUILD_NUMBER     — e.g. 5
#
# Requires: gh CLI authenticated with repo write access.

VERSION="${MVX_RELEASE_VERSION:?MVX_RELEASE_VERSION is required}"
BUILD="${MVX_BUILD_NUMBER:?MVX_BUILD_NUMBER is required}"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
STAGING_DIR="$PROJECT_ROOT/.build/release/staging"

TARBALL_NAME="mvx-${VERSION}-${BUILD}-darwin-aarch64.app.tar.gz"
TARBALL_PATH="$STAGING_DIR/$TARBALL_NAME"
LATEST_JSON="$STAGING_DIR/latest.json"
PUBLICATION_JSON="$STAGING_DIR/release-publication.json"
TAG="v${VERSION}"

# Verify required artifacts exist.
for f in "$TARBALL_PATH" "$LATEST_JSON" "$PUBLICATION_JSON"; do
    if [ ! -f "$f" ]; then
        echo "ERROR: Missing artifact: $f" >&2
        echo "Run ./scripts/release-build first." >&2
        exit 1
    fi
done

# Check gh CLI is available.
if ! command -v gh &>/dev/null; then
    echo "ERROR: gh CLI is required but not found." >&2
    exit 1
fi

echo "==> Publishing mvx $VERSION ($BUILD) to GitHub Release $TAG"

# Check whether the release already exists so we can distinguish that case from
# real failures (auth, network, permission, etc.).
set +e
release_view_output=$(gh release view "$TAG" --json tagName 2>&1)
release_view_exit=$?
set -e

if [ "$release_view_exit" -eq 0 ]; then
    echo "==> Release $TAG already exists, uploading assets..."
    gh release upload "$TAG" \
        "$TARBALL_PATH" \
        "$LATEST_JSON" \
        "$PUBLICATION_JSON" \
        --clobber
elif echo "$release_view_output" | grep -qi "not found" >/dev/null 2>&1; then
    echo "==> Creating new release $TAG..."
    gh release create "$TAG" \
        --title "mvx $VERSION" \
        --generate-notes \
        --prerelease=false \
        "$TARBALL_PATH" \
        "$LATEST_JSON" \
        "$PUBLICATION_JSON"
else
    echo "ERROR: Cannot check release existence: $release_view_output" >&2
    exit 1
fi

echo ""
echo "==> Published to https://github.com/Saewt/mvx/releases/tag/$TAG"
echo "==> latest.json URL: https://github.com/Saewt/mvx/releases/latest/download/latest.json"
